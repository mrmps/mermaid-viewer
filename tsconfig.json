{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./apps/web/*"],
      "@mermaid-viewer/db": ["./packages/db/src"]
    }
  },
  "include": [
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/db/src/**/*.ts",
    "eslint.config.mjs"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
